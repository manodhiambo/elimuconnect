{
  "name": "elimuconnect-api",
  "version": "1.0.0",
  "description": "Backend API for ElimuConnect - Kenyan Education Platform",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "nodemon",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "seed": "ts-node src/scripts/seed.ts",
    "migrate": "ts-node src/scripts/migrate.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t elimuconnect-api .",
    "docker:run": "docker run -p 3001:3001 elimuconnect-api"
  },
  "keywords": [
    "education",
    "kenya",
    "learning",
    "books",
    "past-papers",
    "students",
    "teachers"
  ],
  "author": "ElimuConnect Team",
  "license": "MIT",
  "dependencies": {
    "agenda": "^4.3.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mammoth": "^1.6.0",
    "moment": "^2.30.1",
    "mongoose": "^7.8.7",
    "mongoose-paginate-v2": "^1.9.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "rate-limiter-flexible": "^2.4.2",
    "sharp": "^0.32.5",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.23.0",
    "uuid": "^9.0.1",
    "validator": "^13.15.15",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
