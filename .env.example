# api/.env.example
NODE_ENV=development
PORT=3333

# Database
MONGODB_URI=mongodb://localhost:27017/elimuconnect

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (using Gmail as example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@elimuconnect.com

# SMS Configuration (for Kenya - using Africa's Talking)
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=your-sms-username

# Client URL
CLIENT_URL=http://localhost:4200

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Publisher APIs (for educational content)
KLB_API_KEY=your-klb-api-key
LONGHORN_API_KEY=your-longhorn-api-key

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
