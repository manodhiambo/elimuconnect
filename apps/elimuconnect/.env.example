# Environment Variables for ElimuConnect

# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_APP_URL=http://localhost:3000

# App Configuration
VITE_APP_NAME=ElimuConnect
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="Kenyan Educational Platform"

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHAT=true

# External Services
VITE_SOCKET_URL=http://localhost:5000
VITE_CDN_URL=https://cdn.elimuconnect.ke
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# Analytics
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Social Login
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif

# Development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug
